# Force CRLF line endings for all text files on Windows
* text=auto eol=crlf

# Explicitly mark binary files so they are never touched
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.ico  binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.eot  binary
*.pdf  binary
*.zip  binary
*.tar  binary
*.gz   binary
