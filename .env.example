# Environment Variables — Shrimpy Discord Bot
# Copy this file to .env and fill in your values.
# Never commit your actual .env file!

# ─── Discord ──────────────────────────────────────────────
DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_application_client_id
DISCORD_CLIENT_SECRET=your_application_client_secret
DISCORD_REDIRECT_URI=http://localhost:8080/api/v1/auth/callback

# ─── Database ─────────────────────────────────────────────
# For local Docker: postgres://shrimpy:devpassword@localhost:5432/shrimpy?sslmode=disable
# For Supabase (transaction mode): postgres://postgres.<ref>:<password>@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres
DATABASE_URL=postgres://shrimpy:devpassword@localhost:5432/shrimpy?sslmode=disable

# ─── Security ─────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=replace_with_32_plus_byte_random_string
TOKEN_ENCRYPTION_KEY=replace_with_32_plus_byte_random_string

# ─── API Server ───────────────────────────────────────────
API_PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ─── Bot Settings ─────────────────────────────────────────
BOT_PREFIX=!
ENVIRONMENT=development
LOG_LEVEL=info

# ─── Performance ──────────────────────────────────────────
CACHE_TTL_SECONDS=300
TRANSCRIPT_WORKER_COUNT=4
AUTO_CLOSE_CHECK_INTERVAL=15m
